    "seed:owner:anon": "node scripts/seed-owner-anon.mjs",
    "seed:platform-owner": "node scripts/seed-platform-owner.mjs",
    "invite:staff": "node scripts/invite-staff.mjs",
    "verify:demo-login": "node scripts/verify-demo-login.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@supabase/supabase-js": "^2.38.0",
